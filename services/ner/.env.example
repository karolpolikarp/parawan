# Opcjonalny sekret (puste = brak auth; wystarczające dla usługi na localhost).
PII_NER_API_KEY=

# Model spaCy (lg = najlepszy recall osób; md = lżejszy na słabszym sprzęcie).
PII_NER_MODEL=pl_core_news_lg

# Które etykiety maskować (NKJP): persName=osoby. Dodaj placeName,geogName tylko świadomie.
PII_NER_LABELS=persName

# Placeholder wstawiany w miejsce nazwiska (musi pasować do maski warstwy regex).
PII_NER_MASK=[IMIĘ I NAZWISKO]

# CORS (domyślnie *: aplikacja webowa otwarta z pliku/localhost może wołać usługę).
PII_NER_CORS_ORIGINS=*
